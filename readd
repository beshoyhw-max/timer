python -c "import cv2; import numpy as np; import time; f=np.random.randint(0,255,(1080,1920,3),dtype=np.uint8); t=time.time(); [f.copy() for _ in range(1000)]; print(f'1000 frame copies: {time.time()-t:.2f}s'); t=time.time(); [cv2.resize(f,(960,540)) for _ in range(1000)]; print(f'1000 resizes: {time.time()-t:.2f}s'); t=time.time(); [cv2.cvtColor(f,cv2.COLOR_BGR2GRAY) for _ in range(1000)]; print(f'1000 gray converts: {time.time()-t:.2f}s')"
